{
  "rewrites": [
    {
      "source": "/voucher/:ref",
      "destination": "/voucher.html?ref=:ref"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.casasdavila.com"
        }
      ],
      "destination": "https://casasdavila.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "es.casasdavila.com"
        }
      ],
      "destination": "https://casasdavila.com/pt/",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/pt/",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "locale",
          "value": "(.*)"
        }
      ],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "lightbox",
          "value": "(.*)"
        }
      ],
      "destination": "/:path*",
      "permanent": true
    },
